# Single source of env for backend (spring-dotenv) + docker + frontend.
# Copy to .env and fill values. Never commit .env.

# Database (used by docker-compose MySQL and Spring datasource)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=interviewed
DB_USER=interviewed
DB_PASSWORD=interviewed
DB_ROOT_PASSWORD=root

# Backend
SERVER_PORT=8080
FRONTEND_ORIGIN=http://localhost:5173

# OpenRouter (https://openrouter.ai/keys) — OpenAI-compatible
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api
OPENROUTER_MODEL=openrouter/owl-alpha

# Apify (https://console.apify.com/account/integrations)
APIFY_TOKEN=
APIFY_ACTOR=curious_coder~linkedin-jobs-scraper
APIFY_LINKEDIN_PROFILE_ACTOR=apimaestro~linkedin-profile-detail

# Frontend (Vite needs VITE_ prefix)
VITE_API_BASE_URL=http://localhost:8080
